<% layout("/layouts/boilerplate")%>
<%= success%>

<style>
#tag-filters { display:flex; gap:0.5rem; overflow-x:auto; padding:0.75rem 0; flex-wrap:wrap; }
.tag-chip {
    display:inline-flex; align-items:center; gap:6px;
    padding:6px 14px; border-radius:999px; font-size:0.82rem; cursor:pointer;
    border:1px solid #ddd; background:#fff; color:#444;
    text-decoration:none; transition:all 0.18s; white-space:nowrap;
    font-weight:500;
}
.tag-chip:hover { border-color:#fe424d; color:#fe424d; }
.tag-chip.active { background:#fe424d; color:#fff; border-color:#fe424d; }
.tag-chip i { font-size:0.78rem; }
.clear-filters {
    display:inline-flex; align-items:center; gap:5px;
    padding:6px 14px; border-radius:999px; font-size:0.82rem;
    border:1px dashed #bbb; background:transparent; color:#888;
    text-decoration:none; cursor:pointer; transition:all 0.18s; white-space:nowrap;
}
.clear-filters:hover { border-color:#333; color:#333; }
.tag-badge {
    display:inline-flex; align-items:center; gap:4px;
    padding:3px 9px; border-radius:999px; font-size:0.72rem;
    background:#fff3f4; color:#c0392b; border:1px solid #fcc;
    font-weight:500; margin-right:4px; margin-top:4px;
}
.tag-badge i { font-size:0.68rem; }
.filter-section-label {
    font-size:0.7rem; font-weight:600; text-transform:uppercase;
    letter-spacing:0.05em; color:#999; margin:0.6rem 0.2rem 0.3rem; display:block;
}
.results-note { font-size:0.85rem; color:#888; margin:0.5rem 0 1rem; }
</style>

<div id="tag-filters">
    <%
    const groups = {};
    VALID_TAGS.forEach(tag => {
        const g = TAG_META[tag].group;
        if(!groups[g]) groups[g] = [];
        groups[g].push(tag);
    });
    %>
    <% Object.keys(groups).forEach(group => { %>
        <% groups[group].forEach(tag => { %>
            <%
            const isActive = activeTags.includes(tag);
            const newTags = isActive
                ? activeTags.filter(t => t !== tag)
                : [...activeTags, tag];
            const qStr = newTags.map(t => `tags=${encodeURIComponent(t)}`).join('&');
            const href = '/listings' + (qStr ? '?' + qStr : '');
            %>
            <a href="<%= href %>" class="tag-chip <%= isActive ? 'active' : '' %>">
                <i class="<%= TAG_META[tag].icon %>"></i>
                <%= TAG_META[tag].label %>
            </a>
        <% }); %>
    <% }); %>
    <% if(activeTags.length > 0) { %>
        <a href="/listings" class="clear-filters">
            <i class="fa-solid fa-xmark"></i> Clear all
        </a>
    <% } %>
</div>

<div class="tax-toggle d-flex align-items-center justify-content-between mb-2">
    <p class="results-note mb-0">
        <% if(activeTags.length > 0) { %>
            Showing <strong><%= allListings.length %></strong> listings matching
            <% activeTags.forEach(tag => { %>
                <span class="tag-badge"><i class="<%= TAG_META[tag].icon %>"></i><%= TAG_META[tag].label %></span>
            <% }); %>
        <% } else { %>
            Showing all <strong><%= allListings.length %></strong> listings
        <% } %>
    </p>
    <div class="form-check-reverse form-switch ms-3">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
        <label class="form-check-label" for="switchCheckDefault">+GST</label>
    </div>
</div>

<% if(allListings.length === 0) { %>
    <div class="text-center py-5">
        <i class="fa-solid fa-filter" style="font-size:2.5rem;color:#ddd"></i>
        <p class="mt-3" style="color:#aaa">No listings match your selected filters. <a href="/listings">Clear filters</a></p>
    </div>
<% } %>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for(let listing of allListings){ %>
        <a href="/listings/<%=listing._id%>" class="listing-link">
            <div class="card col">
                <img src="<%=listing.image.url%>" class="card-img-top" alt="listing_img" style="height: 20rem">
                <div class="card-img-overlay"></div>
                <div class="card-body">
                    <p class="card-text">
                        <b><%=listing.title%></b><br/>
                        &#8377;<%=listing.price?listing.price.toLocaleString("en-IN"):"Price not set"%>/night
                        <i class="tax-info">+18% GST</i>
                    </p>
                    <% if(listing.tags && listing.tags.length > 0) { %>
                        <div style="margin-top:8px;">
                            <% listing.tags.slice(0,3).forEach(tag => { %>
                                <span class="tag-badge">
                                    <i class="<%= TAG_META[tag] ? TAG_META[tag].icon : 'fa-solid fa-tag' %>"></i>
                                    <%= TAG_META[tag] ? TAG_META[tag].label : tag %>
                                </span>
                            <% }); %>
                            <% if(listing.tags.length > 3) { %>
                                <span style="font-size:0.72rem;color:#999">+<%=listing.tags.length-3%> more</span>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            </div>
        </a>
    <% } %>
</div>

<script>
    let taxSwitch = document.getElementById('switchCheckDefault');
    taxSwitch.addEventListener('click',()=>{
        let taxInfo = document.getElementsByClassName('tax-info');
        for(let info of taxInfo){
            if(info.style.display!="inline")
                info.style.display="inline";
            else {
                info.style.display="none";
            }
        }
    });
</script>
